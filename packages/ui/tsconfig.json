{
  // ==============================
  // packages/ui 用 TypeScript 設定
  // ==============================
  // - ルートの tsconfig.json を継承し、バンドラー固有の設定のみ上書きする
  // - ルートの strict 系オプションを緩める変更は禁止（型安全性が低下する）
  // - include は src/ のみ。設定ファイル（playwright.config.ts 等）は対象外だが、
  //   VS Code の Language Server で型チェックされる
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    // ブラウザ向け型定義ライブラリ
    "lib": ["DOM", "DOM.Iterable", "ESNext"],

    // 自動取り込みする型定義（ルートの types: [] を上書き）
    "types": ["bun"],

    // ビルド出力先ディレクトリ
    "outDir": "./dist",

    // パスエイリアス
    "paths": {
      "@ui/*": ["./src/*"],
      "@/*": ["../../apps/web/app/*"],
      // CSF Factories のサブパスインポート（import preview from "#.storybook/preview"）を解決する。
      // package.json の imports フィールドはランタイム用、こちらは TypeScript の型解決用。
      // rootDir で解決する方法もあるが、apps/web のファイルを参照しているため rootDir を限定できない。
      "#.storybook/*": ["./.storybook/*"]
    }
  },
  // css.d.ts: tsgo が .storybook/preview.tsx の CSS import もチェックするため型宣言が必要
  "include": ["src/**/*", "css.d.ts"],
  "exclude": ["node_modules", "dist", "vrt", "storybook-static"]
}
